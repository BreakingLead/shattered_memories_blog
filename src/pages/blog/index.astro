---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import "../../styles/blog-index.css";

const posts = (await getCollection("blog")).sort((a, b) =>
    a.id.localeCompare(b.id, "zh-Hans-CN"),
);

const directories = new Map<string, typeof posts>();

for (const post of posts) {
    const segments = post.id.split("/");
    const directory =
        segments.length > 1 ? segments.slice(0, -1).join("/") : "/";
    const group = directories.get(directory) ?? [];
    group.push(post);
    directories.set(directory, group);
}

const directoryGroups = [...directories.entries()].sort(([a], [b]) => {
    if (a === "/") {
        return -1;
    }
    if (b === "/") {
        return 1;
    }
    return a.localeCompare(b, "zh-Hans-CN");
});

const directoryCount = directoryGroups.length;
const postCount = posts.length;
const latestPost = [...posts].sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)[0];
const dateFormatter = new Intl.DateTimeFormat("en-us", {
    year: "numeric",
    month: "short",
    day: "numeric",
});
const folderGroups = directoryGroups.map(([directory, directoryPosts]) => ({
    directory,
    posts: directoryPosts.map((post) => {
        const filename = `${post.id.split("/").at(-1)}.${post.filePath?.split(".").at(-1) ?? "md"}`;
        const description = post.data.description ?? "";

        return {
            id: post.id,
            title: post.data.title,
            description,
            pubDate: post.data.pubDate.toISOString(),
            formattedDate: dateFormatter.format(post.data.pubDate),
            filename,
            href: `/blog/${post.id}/`,
            path: `/blog/${post.id}`,
            isLatest: post.id === latestPost?.id,
            searchText:
                `${directory} ${post.data.title} ${description} /blog/${post.id} ${filename}`.toLowerCase(),
        };
    }),
}));
const recentPosts = [...folderGroups.flatMap((group) => group.posts)].sort(
    (a, b) =>
        new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf() ||
        a.title.localeCompare(b.title, "zh-Hans-CN"),
);

const sanitizePanelId = (directory: string, index: number) =>
    `folder-panel-${index}-${directory.replaceAll(/[^a-zA-Z0-9_-]/g, "-")}`;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Blog | ${SITE_TITLE}`}
            description={SITE_DESCRIPTION}
        />
    </head>
    <body>
        <Header />
        <main class="blog-browser">
            <header class="browser-header">
                <div>
                    <p class="browser-kicker">/src/content/blog</p>
                    <h1>Blog Files</h1>
                    <p class="browser-summary">
                        Browse notes as a folder tree. Published Markdown and
                        MDX entries are listed with their generated route, date,
                        and short description.
                    </p>
                </div>
                <div class="browser-actions">
                    <div class="browser-stats" aria-label="Blog library stats">
                        <span>{directoryCount} folders</span>
                        <span>{postCount} files</span>
                    </div>
                    <div class="browser-controls">
                        <div class="view-toggle" aria-label="Blog list order">
                            <button
                                class="view-toggle-button"
                                type="button"
                                aria-pressed="true"
                                data-view-mode="folders"
                            >
                                Folders
                            </button>
                            <button
                                class="view-toggle-button"
                                type="button"
                                aria-pressed="false"
                                data-view-mode="recent"
                            >
                                Recent
                            </button>
                        </div>
                        <label class="blog-search">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m21 21-4.3-4.3"></path>
                                <circle cx="11" cy="11" r="7"></circle>
                            </svg>
                            <input
                                type="search"
                                placeholder="Filter files"
                                aria-label="Filter blog files"
                                autocomplete="off"
                                data-blog-filter
                            />
                        </label>
                        <button
                            class="folder-action"
                            type="button"
                            data-latest-post
                        >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 5v14M5 12h14"></path>
                            </svg>
                            <span>Latest</span>
                        </button>
                        <button
                            class="folder-action"
                            type="button"
                            aria-expanded="true"
                            data-toggle-all-folders
                        >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M4 6h16M4 12h16M4 18h16"></path>
                            </svg>
                            <span data-toggle-all-label>Collapse all</span>
                        </button>
                    </div>
                </div>
            </header>

            <section class="path-bar" aria-label="Current path">
                <span class="path-prompt">$</span>
                <span>ls -la ./blog</span>
                <span class="path-result" data-filter-status>
                    {postCount} files visible
                </span>
            </section>

            <section
                class="folder-list"
                aria-label="Blog posts by folder"
                data-blog-view="folders"
            >
                {
                    folderGroups.map((group, index) => {
                        const panelId = sanitizePanelId(group.directory, index);

                        return (
                            <section
                                class="folder-group"
                                data-folder={group.directory}
                                data-open="true"
                            >
                                <button
                                    class="folder-heading"
                                    type="button"
                                    aria-expanded="true"
                                    aria-controls={panelId}
                                    data-folder-heading
                                >
                                    <span
                                        class="folder-toggle"
                                        aria-hidden="true"
                                    >
                                        <svg viewBox="0 0 24 24">
                                            <path d="m9 6 6 6-6 6"></path>
                                        </svg>
                                    </span>
                                    <span class="folder-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24">
                                            <path d="M3 7.5A2.5 2.5 0 0 1 5.5 5H10l2 2h6.5A2.5 2.5 0 0 1 21 9.5v7A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5v-9Z">
                                            </path>
                                        </svg>
                                    </span>
                                    <span>
                                        <span class="folder-title">
                                            {group.directory}
                                        </span>
                                        <span class="folder-count">
                                            {group.posts.length} file{
                                                group.posts.length === 1
                                                    ? ""
                                                    : "s"
                                            }
                                        </span>
                                    </span>
                                </button>

                                <div class="folder-panel" id={panelId}>
                                    <ul class="file-list">
                                        {group.posts.map((post) => (
                                            <li
                                                class="file-row"
                                                data-search-text={post.searchText}
                                                data-post-id={post.id}
                                                data-latest={
                                                    post.isLatest ? "true" : "false"
                                                }
                                            >
                                                <a
                                                    href={post.href}
                                                    class="file-link"
                                                >
                                                    <span
                                                        class="file-icon"
                                                        aria-hidden="true"
                                                    >
                                                        <svg viewBox="0 0 24 24">
                                                            <path d="M6 3.5h8l4 4v13H6v-17Z">
                                                            </path>
                                                            <path d="M14 3.5v4h4">
                                                            </path>
                                                            <path d="M9 12h6M9 15h6M9 18h4">
                                                            </path>
                                                        </svg>
                                                    </span>
                                                    <span class="file-main">
                                                        <span class="file-title-row">
                                                            <span class="file-title">
                                                                {post.title}
                                                            </span>
                                                            {post.isLatest && (
                                                                <span class="latest-badge">
                                                                    Latest
                                                                </span>
                                                            )}
                                                        </span>
                                                        <span class="file-description">
                                                            {post.description}
                                                        </span>
                                                        <span class="file-path">
                                                            {post.path}
                                                        </span>
                                                    </span>
                                                    <span class="file-meta">
                                                        <span class="file-name">
                                                            {post.filename}
                                                        </span>
                                                        <time datetime={post.pubDate}>
                                                            {post.formattedDate}
                                                        </time>
                                                    </span>
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </section>
                        );
                    })
                }
                <section
                    class="folder-group recent-group"
                    data-folder="recent"
                    data-open="true"
                    data-recent-group
                    hidden
                >
                    <button
                        class="folder-heading"
                        type="button"
                        aria-expanded="true"
                        aria-controls="folder-panel-recent"
                        data-folder-heading
                    >
                        <span class="folder-toggle" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <path d="m9 6 6 6-6 6"></path>
                            </svg>
                        </span>
                        <span class="folder-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <path d="M5 4v16M19 4v16M8 7h8M8 12h8M8 17h8">
                                </path>
                            </svg>
                        </span>
                        <span>
                            <span class="folder-title">recent</span>
                            <span class="folder-count">
                                {recentPosts.length} file{
                                    recentPosts.length === 1 ? "" : "s"
                                }
                            </span>
                        </span>
                    </button>

                    <div class="folder-panel" id="folder-panel-recent">
                        <ul class="file-list">
                            {recentPosts.map((post) => (
                                <li
                                    class="file-row"
                                    data-search-text={post.searchText}
                                    data-post-id={post.id}
                                    data-latest={post.isLatest ? "true" : "false"}
                                >
                                    <a href={post.href} class="file-link">
                                        <span class="file-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M6 3.5h8l4 4v13H6v-17Z">
                                                </path>
                                                <path d="M14 3.5v4h4"></path>
                                                <path d="M9 12h6M9 15h6M9 18h4">
                                                </path>
                                            </svg>
                                        </span>
                                        <span class="file-main">
                                            <span class="file-title-row">
                                                <span class="file-title">
                                                    {post.title}
                                                </span>
                                                {post.isLatest && (
                                                    <span class="latest-badge">
                                                        Latest
                                                    </span>
                                                )}
                                            </span>
                                            <span class="file-description">
                                                {post.description}
                                            </span>
                                            <span class="file-path">
                                                {post.path}
                                            </span>
                                        </span>
                                        <span class="file-meta">
                                            <span class="file-name">
                                                {post.filename}
                                            </span>
                                            <time datetime={post.pubDate}>
                                                {post.formattedDate}
                                            </time>
                                        </span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                </section>
                <p class="empty-state" hidden data-empty-state>
                    No matching posts.
                </p>
            </section>
        </main>
        <Footer />
        <script>
            const folderStateKey = "blog-folder-state:v1";
            const focusDuration = 1400;
            const filterInput =
                document.querySelector<HTMLInputElement>("[data-blog-filter]");
            const filterStatus =
                document.querySelector<HTMLElement>("[data-filter-status]");
            const toggleAllButton =
                document.querySelector<HTMLButtonElement>(
                    "[data-toggle-all-folders]",
                );
            const toggleAllLabel =
                document.querySelector<HTMLElement>("[data-toggle-all-label]");
            const latestButton =
                document.querySelector<HTMLButtonElement>("[data-latest-post]");
            const emptyState =
                document.querySelector<HTMLElement>("[data-empty-state]");
            const folderList =
                document.querySelector<HTMLElement>("[data-blog-view]");
            const viewButtons = Array.from(
                document.querySelectorAll<HTMLButtonElement>("[data-view-mode]"),
            );
            const folderGroups = Array.from(
                document.querySelectorAll<HTMLElement>(".folder-group"),
            );
            const directoryGroups = folderGroups.filter(
                (folder) => !folder.hasAttribute("data-recent-group"),
            );
            const recentGroup = document.querySelector<HTMLElement>(
                "[data-recent-group]",
            );
            const fileRows = Array.from(
                document.querySelectorAll<HTMLElement>(".file-row"),
            );

            let currentView = "folders";

            const activeGroups = () =>
                currentView === "recent"
                    ? recentGroup
                        ? [recentGroup]
                        : []
                    : directoryGroups;

            const readFolderState = () => {
                try {
                    const rawState = localStorage.getItem(folderStateKey);
                    return rawState ? JSON.parse(rawState) : {};
                } catch {
                    return {};
                }
            };

            const writeFolderState = () => {
                try {
                    const state = Object.fromEntries(
                        directoryGroups.map((folder) => [
                            folder.dataset.folder ?? "",
                            folder.dataset.open !== "false",
                        ]),
                    );
                    localStorage.setItem(folderStateKey, JSON.stringify(state));
                } catch {
                    // Folder state is optional; the browser remains usable without storage.
                }
            };

            const setFolderOpen = (
                folder: HTMLElement,
                shouldOpen: boolean,
                persist = true,
            ) => {
                folder.dataset.open = String(shouldOpen);
                const heading = folder.querySelector<HTMLButtonElement>(
                    "[data-folder-heading]",
                );
                heading?.setAttribute("aria-expanded", String(shouldOpen));

                if (persist) {
                    writeFolderState();
                }
            };

            const updateToggleAll = () => {
                const groups = activeGroups();
                const allOpen = groups.every(
                    (folder) => folder.dataset.open !== "false",
                );
                toggleAllButton?.setAttribute("aria-expanded", String(allOpen));
                if (toggleAllLabel) {
                    toggleAllLabel.textContent = allOpen
                        ? "Collapse all"
                        : "Expand all";
                }
            };

            const updateFilter = () => {
                const normalizedFilter = (filterInput?.value ?? "")
                    .toLowerCase()
                    .trim();
                let visibleFiles = 0;
                let visibleFolders = 0;

                if (folderList) {
                    folderList.dataset.blogView = currentView;
                }

                for (const folder of folderGroups) {
                    folder.hidden =
                        currentView === "recent"
                            ? folder !== recentGroup
                            : folder === recentGroup;
                }

                for (const folder of folderGroups) {
                    if (
                        (currentView === "recent" && folder !== recentGroup) ||
                        (currentView === "folders" && folder === recentGroup)
                    ) {
                        continue;
                    }

                    const folderName = (
                        folder.dataset.folder ?? ""
                    ).toLowerCase();
                    const folderMatches =
                        normalizedFilter.length > 0 &&
                        folderName.includes(normalizedFilter);
                    let folderVisibleFiles = 0;

                    for (const row of Array.from(
                        folder.querySelectorAll<HTMLElement>(".file-row"),
                    )) {
                        const matches =
                            !normalizedFilter ||
                            folderMatches ||
                            (row.dataset.searchText ?? "").includes(
                                normalizedFilter,
                            );
                        row.hidden = !matches;
                        if (matches) {
                            folderVisibleFiles += 1;
                            visibleFiles += 1;
                        }
                    }

                    const folderVisible =
                        !normalizedFilter || folderVisibleFiles > 0;
                    folder.hidden = !folderVisible;
                    if (folderVisible) {
                        visibleFolders += 1;
                    }
                    if (normalizedFilter && folderVisibleFiles > 0) {
                        setFolderOpen(folder, true, false);
                    }
                }

                if (filterStatus) {
                    filterStatus.textContent = normalizedFilter
                        ? `${visibleFiles} files in ${visibleFolders} folders`
                        : `${visibleFiles} files visible`;
                }
                if (emptyState) {
                    emptyState.hidden = visibleFiles !== 0;
                }
                updateToggleAll();
            };

            for (const [directory, isOpen] of Object.entries(readFolderState())) {
                const folder = directoryGroups.find(
                    (candidate) => candidate.dataset.folder === directory,
                );
                if (folder && typeof isOpen === "boolean") {
                    setFolderOpen(folder, isOpen, false);
                }
            }

            for (const folder of folderGroups) {
                const heading = folder.querySelector("[data-folder-heading]");
                heading?.addEventListener("click", () => {
                    setFolderOpen(folder, folder.dataset.open === "false");
                    updateToggleAll();
                });
            }

            filterInput?.addEventListener("input", updateFilter);

            for (const button of viewButtons) {
                button.addEventListener("click", () => {
                    currentView = button.dataset.viewMode ?? "folders";
                    for (const candidate of viewButtons) {
                        candidate.setAttribute(
                            "aria-pressed",
                            String(candidate === button),
                        );
                    }
                    updateFilter();
                });
            }

            toggleAllButton?.addEventListener("click", () => {
                const groups = activeGroups();
                const shouldOpen = !groups.every(
                    (folder) => folder.dataset.open !== "false",
                );
                for (const folder of groups) {
                    setFolderOpen(folder, shouldOpen, false);
                }
                if (currentView === "folders") {
                    writeFolderState();
                }
                updateToggleAll();
            });

            latestButton?.addEventListener("click", () => {
                const latestRow =
                    activeGroups()
                        .flatMap((folder) =>
                            Array.from(
                                folder.querySelectorAll<HTMLElement>(".file-row"),
                            ),
                        )
                        .find((row) => row.dataset.latest === "true") ??
                    fileRows.find((row) => row.dataset.latest === "true");
                const latestFolder = latestRow?.closest<HTMLElement>(
                    ".folder-group",
                );
                if (!latestRow || !latestFolder) return;

                if (filterInput) {
                    filterInput.value = "";
                }
                updateFilter();
                setFolderOpen(latestFolder, true);

                window.setTimeout(() => {
                    latestRow.scrollIntoView({
                        behavior: window.matchMedia(
                            "(prefers-reduced-motion: reduce)",
                        ).matches
                            ? "auto"
                            : "smooth",
                        block: "center",
                    });
                    latestRow.classList.add("is-focused");
                    window.setTimeout(
                        () => latestRow.classList.remove("is-focused"),
                        focusDuration,
                    );
                }, 230);
            });

            updateFilter();
            updateToggleAll();
        </script>
    </body>
</html>

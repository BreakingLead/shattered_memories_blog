---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} Shattered Memories.</span>
	<span>Built with Astro and Markdown.</span>
</footer>

<style>
	footer {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 1rem;
		padding: 2rem 1rem 3rem;
		border-top: 1px solid var(--border);
		color: var(--muted);
		font-size: 0.9rem;
		text-align: center;
	}
</style>

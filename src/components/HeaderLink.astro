---
import type { HTMLAttributes } from 'astro/types';
import { withBase } from '../lib/paths';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizePath = (path: string | undefined) => (path || '/').replace(/\/+$/, '') || '/';
const pathname = normalizePath(Astro.url.pathname.replace(import.meta.env.BASE_URL, ''));
const hrefPath = normalizePath(href);
const currentRoot = '/' + (pathname.match(/[^\/]+/)?.[0] || '');
const hrefRoot = '/' + (hrefPath.match(/[^\/]+/)?.[0] || '');
const isActive = hrefPath === pathname || hrefRoot === currentRoot;
---

<a href={withBase(href)} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
